            "format": "uuid"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "productId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "RatingCreateInput": {
        "type": "object",
        "required": [
          "userId",
          "productId",
          "score"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      },
      "RatingUpdateInput": {
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "stack": {
            "type": "string"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stack": {
            "type": "string"
          }
        }
      }
    }
  }
}
