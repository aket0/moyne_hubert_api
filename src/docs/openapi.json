          "productIds"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "productIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "OrderUpdateInput": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "productIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "Rating": {
        "type": "object",
        "required": [
