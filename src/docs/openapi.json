        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenu via POST /api/keys"
      }
    },
    "parameters": {
      "IdPathParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Identifiant UUID de la ressource",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "ProductSortByParam": {
        "name": "sortBy",
        "in": "query",
        "description": "Champ de tri des produits",
        "schema": {
          "type": "string",
          "enum": [
            "name",
            "price",
            "category"
          ]
        }
      },
      "ProductOrderParam": {
        "name": "order",
        "in": "query",
        "description": "Sens de tri",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "asc"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requete invalide (schema ou validation metier)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentification requise ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Action interdite (secret maitre invalide)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ressource introuvable",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Limite de debit depassee",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Erreur interne du serveur",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "ApiKeyCreateInput": {
        "type": "object",
        "required": [
          "masterSecret"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "local-dev"
          },
          "masterSecret": {
            "type": "string",
            "minLength": 1,
            "example": "change_me_master_secret"
          }
        }
      },
      "AccessToken": {
        "type": "object",
        "required": [
          "accessToken",
          "tokenType",
          "expiresIn"
        ],
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "<JWT>"
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "minimum": 1,
            "example": 3600
          }
        }
      },
      "ApiKeyMetadata": {
        "type": "object",
        "required": [
          "id",
          "keyPrefix",
          "isActive",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "keyPrefix": {
            "type": "string",
            "example": "exo_01234567"
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiKeyCreateResponse": {
        "type": "object",
        "required": [
          "message",
          "apiKey",
          "token",
          "metadata"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "apiKey": {
            "type": "string",
            "example": "exo_xxxxx"
          },
          "token": {
            "$ref": "#/components/schemas/AccessToken"
          },
          "metadata": {
            "$ref": "#/components/schemas/ApiKeyMetadata"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "firstName",
          "lastName",
          "email"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "UserCreateInput": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "email"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255
          }
        }
      },
      "UserUpdateInput": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255
          }
        }
      },
      "Product": {
        "type": "object",
        "required": [
          "id",
          "name",
          "price",
          "category"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "ProductCreateInput": {
        "type": "object",
        "required": [
          "name",
          "price",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "price": {
            "type": "number",
            "minimum": 0.01
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      },
      "ProductUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "price": {
            "type": "number",
            "minimum": 0.01
